# HeapDog Environment Configuration
# Copy this file to .env and update the values as needed

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=heapdog
DB_USER=heapdog
DB_PASSWORD=heapdog_secret

# Application Configuration
# IMPORTANT: Change JWT_SECRET in production! Must be at least 32 characters
JWT_SECRET=dev-secret-key-change-in-production-minimum-32-characters-required
BCRYPT_SALT_ROUNDS=10

# For production deployment, use strong, unique values:
# JWT_SECRET=your-super-secure-random-jwt-secret-key-at-least-32-characters-long
# DB_PASSWORD=your-strong-database-password
